{
    // descrip: Shared defaults for every agent. Agent settings override these values.
    // default: edit this file for global behavior, edit agents/<Agent>/settings.jsonc for per-agent differences
    // descrip: OpenRouter API base URL used for chat completions.
    // default: "https://openrouter.ai/api/v1"
    "openrouter_base_url": "https://openrouter.ai/api/v1",

    // descrip: OpenRouter provider routing. Ignored providers are skipped when OpenRouter chooses where to run the model. This is useful when a provider blocks roleplay output even though the model itself is acceptable.
    // default: skip Alibaba because it has returned inappropriate-content upstream errors for adult roleplay
    "openrouter_provider_routing": {
        "ignore": [
            "Alibaba"
        ]
    },

    // descrip: OpenRouter model string used for replies.
    // default: "deepseek/deepseek-v4-flash"
    "model": "deepseek/deepseek-v4-flash",
    // descrip: OpenRouter model string used for small utility decisions like intent checks, status inference, and whether sleep should create a dream.
    // default: "openai/gpt-oss-20b:free"
    "utility_model": "openai/gpt-oss-20b:free",
    // descrip: Optional bot skills loaded for agents unless overridden. Journal, story, thought, and time are core systems and are always loaded.
    // default: discordstatusupdate
    "enabled_skills": [
        "discordstatusupdate"
    ],
    // descrip: Local/web visitor chat settings. This exposes only a slim chat API/page when the web chat server is explicitly started; it does not expose Yculth admin tools.
    // default: enabled for local Tek testing only
    "web_chat": {
        // descrip: Enables the web chat API when discord-bot/web-chat.js is running.
        // range: true or false.
        // default: true for local testing
        "enabled": true,
        // descrip: Agents that visitors are allowed to chat with through the web chat API.
        // default: Tek only for the first controlled test
        "allowed_agents": [
            "Tek"
        ],
        // descrip: Agent used when a visitor does not explicitly choose one.
        // default: "Tek"
        "default_agent": "Tek",
        // descrip: Human-facing title shown on the local visitor chat page.
        // default: "Tek"
        "display_title": "Tek, Pigmy Lizardfolk",
        // descrip: Host for the local web chat server.
        // default: "127.0.0.1"
        "host": "127.0.0.1",
        // descrip: Port for the local web chat server.
        // range: 1 to 65535.
        // default: 8787
        "port": 8787,
        // descrip: If true, visitor conversations use isolated visitor memory under web-chat/visitors instead of the agent's Discord shortmemory.
        // default: true
        "separate_visitor_memory": true,
        // descrip: Optional invite code. If blank, no invite code is required. Use before exposing beyond localhost.
        // default: ""
        "invite_code": "",
        // descrip: Maximum visitor message length accepted by the web chat API.
        // range: 1 or higher.
        // default: 2000
        "max_message_length": 2000,
        // descrip: Maximum generated reply length returned to the browser.
        // range: 1 or higher.
        // default: 4000
        "max_reply_characters": 4000,
        // descrip: Number of recent visitor memory entries sent as raw chat context.
        // range: 1 or higher.
        // default: 100
        "visitor_context_entries": 100,
        // descrip: Show a clear AI disclosure in the visitor chat UI.
        // range: true or false.
        // default: true
        "show_ai_disclosure": true
    },
    // descrip: Pipe command aliases for skills and command names. The key is the canonical command, the list contains extra names users may type. Agent settings can override this locally.
    // default: image can also be called imagegen
    "skill_aliases": {
        "image": [
            "imagegen"
        ]
    },
    // descrip: Persona file to load from each agent folder.
    // default: "soul/persona.md"
    "system_prompt_file": "soul/persona.md",
    // descrip: Repo-level generation defaults applied to every agent model request, including replies, thoughts, dreams, journals, stories, memorysum updates, status updates, and text transformation. This file does not overwrite agent persona files.
    // default: "global-persona.md"
    "global_persona_file": "global-persona.md",
    // descrip: Discord forum post/thread ID used by /reloadpersona. Per-agent override recommended.
    // default: ""
    "persona_source_thread_id": "",
    // descrip: If true and persona_source_thread_id is blank, startup and /reloadpersona may use the memory forum persona post as the persona source. If false, the bot uses the local system_prompt_file unless persona_source_thread_id is explicitly set.
    // range: true or false.
    // default: true
    "use_memory_forum_persona_source": true,
    // descrip: Discord forum post/thread ID the bot may use to read extra agent-specific information later.
    // default: ""
    "access_thread_id": "",
    // descrip: Optional OAuth invite URL for this agent's Discord application. If set, it appears in the help memory post.
    // default: ""
    "discord_invite_url": "",
    // descrip: Discord forum post/thread ID where the bot mirrors shortmemory entries. If blank, the bot looks for a shortmemory post in memory_forum_channel_id.
    // default: ""
    "shortmemory_thread_id": "",
    // descrip: Required Discord forum channel ID for each agent's memory forum. Agents must override this.
    // default: ""
    "memory_forum_channel_id": "",
    // descrip: Core forum post names that startup and /setupmemoryforum create or confirm. Optional skill posts are added only when that skill is enabled and implemented.
    // default: standard memory posts
    "memory_forum_posts": [
        "help",
        "emoji",
        "persona",
        "origin",
        "adjustments",
        "status",
        "profilepic",
        "memorysum",
        "shortmemory",
        "dreams",
        "thoughts",
        "art",
        "stories"
    ],
    // descrip: Code skill settings. The code skill is a conversational adapter to an external coding command you provide.
    // default: disabled until code is listed in enabled_skills and command is configured
    "code_skill": {
        // descrip: Executable path for your external coding command. The bot sends one JSON request on stdin and reads stdout as text or JSON.
        // default: ""
        "command": "",
        // descrip: Extra command arguments passed after command. Keep command and args separate; this skill does not run through a shell.
        // default: []
        "args": [],
        // descrip: Maximum time to wait for the external code command.
        // range: 1 or higher.
        // default: 60000
        "timeout_milliseconds": 60000,
        // descrip: Maximum characters returned to the user from the external code command.
        // range: 1 to 1900 recommended for Discord.
        // default: 1600
        "max_output_characters": 1600
    },
    // descrip: File skill settings. The file skill is a conversational adapter to an external file-management command you provide.
    // default: disabled until file is listed in enabled_skills and command is configured
    "file_skill": {
        // descrip: Executable path for your external file-management command. The bot sends one JSON request on stdin and reads stdout as text or JSON.
        // default: ""
        "command": "",
        // descrip: Extra command arguments passed after command. Keep command and args separate; this skill does not run through a shell.
        // default: []
        "args": [],
        // descrip: Maximum time to wait for the external file command.
        // range: 1 or higher.
        // default: 30000
        "timeout_milliseconds": 30000,
        // descrip: Maximum characters returned to the user from the external file command.
        // range: 1 to 1900 recommended for Discord.
        // default: 1600
        "max_output_characters": 1600
    },
    // descrip: Runprogram skill settings. The runprogram skill is a conversational adapter to an external program runner command you provide.
    // default: disabled until runprogram is listed in enabled_skills and command is configured
    "runprogram_skill": {
        // descrip: Executable path for your external program runner command. The bot sends one JSON request on stdin and reads stdout as text or JSON.
        // default: ""
        "command": "",
        // descrip: Extra command arguments passed after command. Keep command and args separate; this skill does not run through a shell.
        // default: []
        "args": [],
        // descrip: Names and aliases for apps the runner may launch or control. The external runner decides how to interpret these entries.
        // default: empty app registry
        "apps": {
            // descrip: Example app entry. Rename the key and fill command details when you are ready to use it.
            // default: disabled example
            "example": {
                // descrip: Names the agent may use to identify this app.
                // default: []
                "aliases": [],
                // descrip: Executable path or command for this app.
                // default: ""
                "command": "",
                // descrip: Extra arguments for this app.
                // default: []
                "args": [],
                // descrip: Optional working directory for this app.
                // default: ""
                "working_directory": ""
            }
        },
        // descrip: Maximum time to wait for the external runprogram command.
        // range: 1 or higher.
        // default: 30000
        "timeout_milliseconds": 30000,
        // descrip: Maximum characters returned to the user from the external runprogram command.
        // range: 1 to 1900 recommended for Discord.
        // default: 1600
        "max_output_characters": 1600
    },
    // descrip: Music skill site switches. music_thread_id must be overridden when the music skill is enabled.
    // default: only YouTube discovery enabled, no archive thread
    "music_skill": {
        "music_thread_id": "",
        "website_config_url": "",
        "youtube_enabled": true,
        "bandcamp_enabled": false,
        "soundcloud_enabled": false,
        "spotify_enabled": false,
        "apple_music_enabled": false,
        "youtube_music_enabled": false,
        "internet_archive_enabled": false,
        "free_music_archive_enabled": false,
        "jamendo_enabled": false,
        "newgrounds_audio_enabled": false
    },
    // descrip: Speak skill settings. The speak skill is interface-neutral TTS/voice-training plumbing; Discord is only one possible interface.
    // default: Fish Audio provider, disabled until speak is listed in enabled_skills
    "speak_skill": {
        // descrip: Voice output and voice training provider.
        // default: "fishaudio"
        "provider": "fishaudio",
        // descrip: Agent-local secret file for the Fish Audio API key.
        // default: "secrets/fish_audio_api_key.txt"
        "api_key_file": "secrets/fish_audio_api_key.txt",
        // descrip: Fish Audio TTS model header.
        // default: "s2-pro"
        "model": "s2-pro",
        // descrip: Fish Audio cloned voice/reference id used for generated speech. Leave blank until a voice model is trained or chosen.
        // default: ""
        "reference_id": "",
        // descrip: Folder under the agent where generated audio and voice model logs are saved.
        // default: "regenerated/speak"
        "output_folder": "regenerated/speak",
        // descrip: JSONL file under output_folder where voice training API responses are logged.
        // default: "voice-models.jsonl"
        "voice_model_log_file": "voice-models.jsonl",
        // descrip: Fish Audio generated audio format.
        // default: "mp3"
        "format": "mp3",
        // descrip: Fish Audio latency-quality mode.
        // default: "normal"
        "latency": "normal",
        // descrip: Speech speed multiplier.
        // range: 0.5 to 2.
        // default: 1
        "speed": 1,
        // descrip: Fish Audio prosody volume adjustment.
        // range: -20 to 20.
        // default: 0
        "volume": 0,
        // descrip: Visibility for newly trained Fish Audio voice models.
        // default: "private"
        "training_visibility": "private",
        // descrip: If true, Fish Audio may clean and normalize training audio before creating a voice model.
        // default: true
        "enhance_audio_quality": true,
        // descrip: Maximum Discord audio attachment bytes accepted for voice training upload.
        // range: 1 or higher.
        // default: 25000000
        "max_training_audio_bytes": 25000000
    },
    // descrip: Textgen skill settings. Textgen is an optional generation skill for intent-preserving text transformation. Its first mode is remux: same intent, different language container.
    // default: sfw-discord remux styles, history saved locally
    "textgen_skill": {
        // descrip: Style preset used when the textgen request does not mention an existing style by name.
        // default: "sfw-discord"
        "default_style": "sfw-discord",
        // descrip: Agent-local folder containing textgen style preset JSONC files.
        // default: "soul/textgen/styles"
        "styles_folder": "soul/textgen/styles",
        // descrip: Agent-local folder where textgen request and output history is saved.
        // default: "soul/textgen/history"
        "history_folder": "soul/textgen/history",
        // descrip: If true, textgen saves remux input and output history locally for later review.
        // range: true or false.
        // default: true
        "save_history": true
    },
    // descrip: Vision skill settings. The vision skill describes attached images, but does not update memory or image-generation guidance by itself.
    // default: use a vision-capable OpenRouter model
    "vision_skill": {
        // descrip: OpenRouter model string used for image description.
        // default: "meta-llama/llama-3.2-11b-vision-instruct"
        "model": "meta-llama/llama-3.2-11b-vision-instruct",
        // descrip: Maximum image attachment bytes the bot will send to the vision model.
        // range: 1 or higher.
        // default: 6000000
        "max_image_bytes": 6000000,
        // descrip: Maximum characters to return in one vision description reply.
        // range: 1 or higher.
        // default: 1800
        "max_output_characters": 1800
    },
    // descrip: Cheap local trigger words that decide whether a skill is allowed to spend tokens on an AI intent check. If no trigger matches, no AI intent check happens.
    // default: music triggers only
    "intent_triggers": {
        // descrip: Words and phrases that may mean the user wants a music link. Matching these only starts the AI intent check; it does not automatically post music by itself.
        // default: minimal music request words
        "music": [
            "song",
            "music"
        ]
    },
    // descrip: Natural-language status update settings. These status notes are written into soul/status.json and mirrored to the status memory thread after summarization. Core sleep, dream, and status fields are read directly; source_skills is only for optional extra hints.
    // default: allow implemented major context skills to influence status text
    "discord_status_update": {
        // descrip: Skills allowed to provide optional status hints. Unknown, disabled, or unavailable skill names are ignored.
        // default:
        "source_skills": [
            "story",
            "music"
        ]
    },
    // descrip: Placeholder settings for planned skills. These do not do anything until the matching skill is implemented.
    // default: all disabled placeholders
    "planned_skill_settings": {
        "characterproxy": {
            "enabled": false
        },
        "emoji": {
            "enabled": false
        },
        "gamemaster": {
            "enabled": false
        },
        "musiccomposition": {
            // descrip: Placeholder for future music composition from natural-language intent, references, memories, or style settings.
            // default: false
            "enabled": false
        },
        "profilepic": {
            "enabled": false
        },
        "art": {
            "enabled": false
        },
        "settings": {
            "enabled": false
        },
        "tts": {
            // descrip: Older placeholder for normal expressive voice output. Prefer implemented speak_skill for runtime TTS and voice-training hooks.
            // default: false
            "enabled": false,
            // descrip: Voice output provider name.
            // default: "fishaudio"
            "provider": "fishaudio",
            // descrip: Fish Audio model header.
            // default: "s2-pro"
            "model": "s2-pro",
            // descrip: Fish Audio reference_id or cloned voice ID. Leave blank to use Fish Audio default behavior.
            // default: ""
            "voice_id": "",
            // descrip: Agent-local secret file for the Fish Audio API key.
            // default: "secrets/fish_audio_api_key.txt"
            "api_key_file": "secrets/fish_audio_api_key.txt",
            // descrip: Generated audio format.
            // default: "mp3"
            "format": "mp3",
            // descrip: Fish Audio latency-quality mode.
            // default: "normal"
            "latency": "normal",
            // descrip: Speech speed multiplier.
            // range: 0.5 to 2.
            // default: 1
            "speed": 1,
            // descrip: Fish Audio prosody volume adjustment.
            // range: -20 to 20.
            // default: 0
            "volume": 0
        },
        "videogeneration": {
            // descrip: Placeholder for future video generation from natural-language intent, references, memories, or style settings.
            // default: false
            "enabled": false
        },
        "visualexpression": {
            // descrip: Placeholder for future AI-chosen generated visuals that can accompany speech, thoughts, scenes, dreams, backgrounds, self-images, and custom emojis. Yculth imagegen is the first local generation surface.
            // default: false
            "enabled": false,
            // descrip: Local generation target. This should stay local-first until Discord posting behavior is intentionally designed.
            // default: "yculth-imagegen"
            "provider": "yculth-imagegen",
            // descrip: Maximum seconds future visual generation may wait for the provider before recording a timeout failure.
            // range: 1 or higher.
            // default: 120
            "provider_timeout_seconds": 120,
            // descrip: Maximum automatic retries for retryable visual provider failures.
            // range: 0 or higher.
            // default: 1
            "provider_max_retries": 1,
            // descrip: If true, normal text replies may still be sent when an optional visual generation fails.
            // default: true
            "continue_reply_when_visual_fails": true,
            // descrip: Visual output types the agent may eventually request when the skill is implemented.
            // default: emoji, self, scene, background, thought, dream
            "output_types": [
                "emoji",
                "self",
                "scene",
                "background",
                "thought",
                "dream"
            ],
            // descrip: If true, future implementation may use utility_model to decide when a reply benefits from a generated visual.
            // default: true
            "allow_ai_visual_intent": true,
            // descrip: If true, future implementation may accept planned visual pipe commands such as ||@agent visual scene: text||.
            // default: false
            "allow_manual_pipe_commands": false,
            // descrip: Minimum utility-model confidence needed before future tooling queues a visual request.
            // range: 0 to 1.
            // default: 0.75
            "intent_confidence_threshold": 0.75,
            // descrip: Minimum time between automatic visual requests for one agent, to prevent image spam during fast chat.
            // range: 0 or higher.
            // default: 10
            "cooldown_minutes": 10,
            // descrip: Maximum generated visuals attached to one normal reply.
            // range: 0 or higher.
            // default: 1
            "max_visuals_per_reply": 1,
            // descrip: Maximum visual variants future tooling may generate for one visual request before review.
            // range: 1 or higher.
            // default: 3
            "max_variants_per_request": 3,
            // descrip: Default variant strategy for future visual requests.
            // default: "same prompt, different seeds"
            "default_variant_strategy": "same prompt, different seeds",
            // descrip: Maximum characters of selected memory/reference context to use while assembling a future visual prompt.
            // range: 0 or higher.
            // default: 4000
            "prompt_context_character_limit": 4000,
            // descrip: Optional agent-local JSONC file for reusable visual style presets.
            // default: "soul/visual-style-presets.jsonc"
            "style_presets_file": "soul/visual-style-presets.jsonc",
            // descrip: Default style preset for generated custom emoji.
            // default: "emoji-clean"
            "default_emoji_style_preset": "emoji-clean",
            // descrip: Default style preset for generated self-images and portraits.
            // default: "self-portrait"
            "default_self_style_preset": "self-portrait",
            // descrip: Default style preset for generated scenes.
            // default: "scene-readable"
            "default_scene_style_preset": "scene-readable",
            // descrip: Default style preset for generated backgrounds.
            // default: "background-mood"
            "default_background_style_preset": "background-mood",
            // descrip: Default style preset for generated thought images.
            // default: "thought-symbol"
            "default_thought_style_preset": "thought-symbol",
            // descrip: Default style preset for generated dream images.
            // default: "dream-surreal"
            "default_dream_style_preset": "dream-surreal",
            // descrip: Maximum visual reference IDs to include in one future visual prompt.
            // range: 0 or higher.
            // default: 3
            "max_reference_ids_per_prompt": 3,
            // descrip: Maximum visual reference notes to read while selecting references for one future prompt.
            // range: 0 or higher.
            // default: 8
            "max_reference_notes_to_scan": 8,
            // descrip: If true, future reference selection may use output_type to filter likely matching references before reading notes.
            // default: true
            "prefer_output_type_reference_matches": true,
            // descrip: Agent-local folder for generated visual expression outputs.
            // default: "regenerated/visualexpression"
            "output_folder": "regenerated/visualexpression",
            // descrip: Manifest file inside output_folder that records completed generated visual expressions.
            // default: "outputs.jsonl"
            "output_manifest_file": "outputs.jsonl",
            // descrip: JSONL file inside output_folder that records human or future AI review notes for generated visuals.
            // default: "reviews.jsonl"
            "visual_review_file": "reviews.jsonl",
            // descrip: If true, future visual tooling should require preview or review before promotion into soul/art or soul/emojis.
            // default: true
            "require_review_before_promotion": true,
            // descrip: Minimum review score future tooling should suggest for automatic promotion candidates. Human override still wins.
            // range: 1 to 5.
            // default: 4
            "promotion_candidate_min_score": 4,
            // descrip: JSONL file inside output_folder that future tooling can use to record requested/generated visual expressions.
            // default: "requests.jsonl"
            "request_log_file": "requests.jsonl",
            // descrip: JSONL file inside output_folder that future tooling can use to record compact visual memory entries for recall.
            // default: "visual-memory.jsonl"
            "visual_memory_file": "visual-memory.jsonl",
            // descrip: Maximum visual memory entries future context assembly may include in one model request.
            // range: 0 or higher.
            // default: 4
            "max_visual_memories_per_context": 4,
            // descrip: Maximum recent visual request lifecycle events future UI should show by default.
            // range: 0 or higher.
            // default: 50
            "recent_request_events_to_show": 50,
            // descrip: If true, future Yculth visual UI should show generated experiments from regenerated/visualexpression by default.
            // default: true
            "show_generated_outputs_in_yculth": true,
            // descrip: If true, future Yculth visual UI should show downloaded references from soul/visual-references by default.
            // default: true
            "show_visual_references_in_yculth": true,
            // descrip: Number of days to keep unpromoted generated visual experiments before future cleanup may offer to remove them.
            // range: 0 or higher.
            // default: 30
            "generated_output_retention_days": 30,
            // descrip: If true, future cleanup should move generated visual files to trash instead of deleting permanently.
            // default: true
            "cleanup_moves_to_trash": true,
            // descrip: If true, future cleanup must preserve any generated output that was promoted into soul/art or soul/emojis.
            // default: true
            "preserve_promoted_outputs": true,
            // descrip: If true, future visual tooling may post selected generated outputs to Discord. Keep false until local preview workflow is reliable.
            // default: false
            "allow_discord_posting": false,
            // descrip: If true, future Discord posting requires the generated visual to be previewed locally before posting.
            // default: true
            "discord_posting_requires_preview": true,
            // descrip: Maximum generated visual attachments future tooling may include in one Discord message.
            // range: 1 or higher.
            // default: 1
            "discord_posting_max_images_per_message": 1,
            // descrip: Optional Discord channel or thread id for future visual posts. Leave blank to post beside the triggering conversation when posting is allowed.
            // default: ""
            "discord_posting_target_channel_id": "",
            // descrip: Agent-local folder for human-downloaded or tool-downloaded visual references. This is source material, not generated output.
            // default: "soul/visual-references"
            "reference_folder": "soul/visual-references",
            // descrip: Manifest file inside reference_folder that records downloaded or manually collected visual references.
            // default: "manifest.jsonl"
            "reference_manifest_file": "manifest.jsonl",
            // descrip: JSONL file inside reference_folder that records future internet search requests and candidate reference results before download.
            // default: "searches.jsonl"
            "reference_search_log_file": "searches.jsonl",
            // descrip: Optional websites or search pages to use as visual reference starting points. Keep blank until a source is intentionally chosen.
            // default: []
            "reference_sources": [],
            // descrip: Maximum candidate reference results future tooling may keep from one internet search before review.
            // range: 0 or higher.
            // default: 12
            "max_reference_candidates_per_search": 12,
            // descrip: If true, future implementation may download visual references from configured sources into reference_folder. It should store source URLs and attribution notes with downloads.
            // default: false
            "allow_internet_reference_downloads": false,
            // descrip: If true, future visual reference candidates should be reviewed before they become downloaded manifest entries.
            // default: true
            "require_reference_review_before_download": true,
            // descrip: Maximum internet reference downloads allowed for one future acquisition request.
            // range: 0 or higher.
            // default: 3
            "max_reference_downloads_per_request": 3,
            // descrip: Allowed MIME types for future visual reference downloads.
            // default: common web image MIME types
            "allowed_reference_mime_types": [
                "image/jpeg",
                "image/png",
                "image/webp",
                "image/gif"
            ],
            // descrip: If true, future internet reference downloads should be shown for local review before being used in prompt assembly.
            // default: true
            "preview_downloaded_references_before_use": true,
            // descrip: If true, future implementation must keep source URL, creator/license when known, and download time beside downloaded references.
            // default: true
            "require_reference_attribution_notes": true,
            // descrip: If true, future tooling may offer a promote button for generated visuals. Promotion should still be user-confirmed.
            // default: true
            "allow_manual_promotion": true,
            // descrip: Destination folder for generated visuals promoted into durable character art.
            // default: "soul/art"
            "promoted_art_folder": "soul/art",
            // descrip: Destination folder for generated visuals promoted into durable custom emoji material.
            // default: "soul/emojis"
            "promoted_emoji_folder": "soul/emojis"
        }
    },
    // descrip: Number of recent shortmemory entries and live conversation entries sent privately to OpenRouter for normal replies. This is not how much is saved; shortmemory can save the whole day locally. Higher improves recall but every reply resends more text and costs more input tokens.
    // range: 0 or higher; practical range is 100 to 300 for strong chat recall.
    // default: 300
    "recent_context_entries": 300,
    // descrip: Deprecated older name kept only as a fallback if recent_context_entries is missing. Prefer editing recent_context_entries.
    // range: 0 or higher.
    // default: 300
    "conversation_history_limit": 300,
    // descrip: Seconds to wait before a normal reply, then re-check that the source message still exists before spending OpenRouter tokens. Set to 0 to disable. This was a Tupper hack for bots that delete/replace user messages.
    // range: 0 or higher.
    // default: 0
    "seconds_before_reply": 0,
    // descrip: Natural roleplay time settings. Before normal replies, the core time system can ask utility_model whether the user's message clearly implies time passed, then update soul/status.json and include that elapsed time as hidden context.
    // default: enabled, conservative confidence, vague time capped at 8 hours
    "natural_time_settings": {
        // descrip: If true, normal replies may infer roleplay time from clear natural-language cues like after a shower, later, next morning, or three days later.
        // range: true or false.
        // default: true
        "enabled": true,
        // descrip: Minimum utility_model confidence required before inferred time updates status. Higher means fewer accidental time jumps.
        // range: 0 to 1.
        // default: 0.75
        "minimum_confidence": 0.75,
        // descrip: Maximum minutes allowed for vague inferred time such as later or after a while. Explicit wording like three hours later uses explicit_max_minutes instead.
        // range: 1 or higher.
        // default: 480
        "vague_max_minutes": 480,
        // descrip: Maximum minutes allowed for explicit inferred time such as three days later. This prevents accidental huge jumps from malformed model output.
        // range: 1 or higher.
        // default: 525600
        "explicit_max_minutes": 525600,
        // descrip: Recent live conversation entries sent to utility_model for the time inference decision.
        // range: 0 or higher.
        // default: 8
        "recent_context_entries": 8
    },
    // descrip: Visible debug header for tuning agent roleplay time. If enabled, normal generated replies start with the current in-game datetime and how much roleplay time advanced before that reply.
    // default: disabled for normal roleplay
    "agent_time_debug": {
        // descrip: If true, normal generated replies begin with a visible in-game time/debug header.
        // range: true or false.
        // default: false
        "enabled": false,
        // descrip: If true, include the latest time-passage reason when one exists.
        // range: true or false.
        // default: true
        "show_reason": true,
        // descrip: If true, show current_datetime in a compact local-readable format instead of raw ISO text.
        // range: true or false.
        // default: true
        "compact_datetime": true
    },
    // descrip: Summarization settings control automatic memory maintenance. Summarizing creates durable memory entries and updates compact memorysum, then clears temporary thoughts after successful memory absorption.
    // default: soul/shortmemory.jsonl plus thoughts/journals/dreams/stories/neural memory input, soul/memorysum.txt output, soul/memory entries
    "summarization_settings": {
        // descrip: Memorysum instruction. Memorysum must keep # Past, # Present, and # Future / Plans sections. Keep durable user-specific facts when they help future replies, such as names, stable preferences, boundaries, relationships, ongoing situations, and important context. Do not save throwaway moods, one-off wording, private subtext, or raw transcripts unless they became durably important.
        // default: remember durable per-user context, not everything
        "summary_policy": "remember durable per-user context, not everything",
        // descrip: Maximum recent shortmemory lines to include in one daily memory run during sleep/dream memory maintenance. Older shortmemory is not read directly during that run; it should already be represented in soul/memorysum.txt from earlier memory updates.
        // range: 1 or higher.
        // default: 1000
        "daily_summary_entries": 1000,
        // descrip: If true, entering sleep runs the daily memory update in the background as part of the sleep/dream cycle.
        // range: true or false.
        // default: true
        "summarize_on_sleep": true
    },
    // descrip: Shortmemory trash settings control how long user-trashed shortmemory entries remain recoverable before automatic memory cleanup removes them.
    // default: keep trash for 7 successful automatic memory cycles
    "shortmemory_trash": {
        // descrip: Number of successful scheduled automatic memory cycles to keep trashed shortmemory entries. This uses cycle counts instead of calendar dates so a wrong system clock cannot instantly delete the wrong memories.
        // range: 1 or higher.
        // default: 7
        "keep_auto_summary_cycles": 7
    },
    // descrip: Daily memory cycle settings control backup checks for the automatic consciousness cycle. The cycle still only runs when enough new memory entries accumulated.
    // default: check after about 24 hours of bot runtime
    "daily_memory_cycle": {
        // descrip: Bot runtime hours between backup consciousness-cycle checks. Time while the bot is offline does not count.
        // range: 1 or higher.
        // default: 24
        "automatic_cycle_hours": 24
    },
    // descrip: Consciousness cycle settings estimate when about one day of meaningful interaction has accumulated. The cycle generates neural memory, journal, dream, memory entries, memorysum, then clears temporary thoughts after the memory update succeeds.
    // default: one cycle after about 288 memory entries
    "consciousness_cycle": {
        // descrip: Estimated seconds between meaningful memory entries. Used to estimate how many entries roughly equal one day of interaction. For example, 300 means about one entry every 5 minutes.
        // range: 1 or higher.
        // default: 300
        "seconds_per_message": 300,
        // descrip: Number of hours that should count as one memory cycle. The default 24 means the system tries to summarize about one day of interaction at a time.
        // range: 1 or higher.
        // default: 24
        "cycle_hours": 24
    },
    // descrip: Consciousness cleanup settings. Cleanup only applies to backup files/folders under the agent backups folder, never to active soul or memory files.
    // default: keep backups 7 days, move expired backups to OS trash, never permanently delete by default
    "consciousness": {
        "cleanup": {
            // descrip: Number of days to keep backup files before they are eligible for cleanup.
            // range: 1 or higher.
            // default: 7
            "backup_retention_days": 7,
            // descrip: When true, expired backups are moved to the operating system trash / Windows Recycle Bin. If OS trash fails, backups are left untouched.
            // range: true or false.
            // default: true
            "move_expired_backups_to_os_trash": true,
            // descrip: When true, expired backups are permanently deleted instead of moved to OS trash. Dangerous; must stay false unless you explicitly accept permanent deletion.
            // range: true or false.
            // default: false
            "permanently_delete_expired_backups": false
        }
    },
    // descrip: Neural memory settings describe the future consciousness loop memory system. This is inert for now and does not affect replies while mode is off.
    // default: off, read 1000 entries, write about 100 downscaled memory nodes
    "neural_memory": {
        // descrip: Controls how neural memory participates in replies. "off" means neural memory is not used in replies. "debug" means neural memory is built and shown with tiny safe reply influence for testing. "on" means selected neural memory can affect replies normally.
        // range: off, debug, or on.
        // default: off
        "mode": "off",
        // descrip: Number of recent memory entries used to write the agent's private first-person thought before a visible reply.
        // range: 1 or higher.
        // default: 10
        "thought_window_entries": 10,
        // descrip: Number of recent memory entries sent as raw conversation context for the visible reply.
        // range: 1 or higher.
        // default: 100
        "reply_window_entries": 100,
        // descrip: Number of recent memory entries read by neural memory semantic downscale.
        // range: 1 or higher; should be greater than or equal to reply_window_entries.
        // default: 1000
        "read_entries": 1000,
        // descrip: Approximate number of downscaled neural memory nodes to write from read_entries.
        // range: 1 or higher; should usually be much smaller than read_entries.
        // default: 100
        "write_nodes": 100
    },
    // descrip: Consciousness descriptors define what each generated artifact is. They are human-editable model-facing instructions for thought, feeling, journal, dream, dreamjournal, story, memory, memorysum, neural memory, and reply behavior.
    // default: first-person private thought/feeling, durable journal/dream/story/memory artifacts, visible reply separation, and compact memorysum updates.
    "consciousness_descriptors": {
        // descrip: Instruction for generating the private thought attached to a reply.
        // default: private first-person internal monologue
        "thought": "Write my private first-person internal monologue for this moment. Focus on what I am thinking or feeling right now, including anything I might not say out loud.",
        // descrip: Instruction for generating the private emotional/body/atmosphere feeling attached to a reply.
        // default: private first-person emotional and bodily feeling
        "feeling": "Write my private first-person emotional and bodily feeling for this moment. Focus on mood, sensation, atmosphere, tension, comfort, fear, desire, fatigue, instinct, and what my body/emotions are doing beneath the visible reply. Do not explain mechanics.",
        // descrip: Instruction for generating the visible reply.
        // default: visible reply that does not reveal private thought unless natural
        "reply": "Write my visible reply to the user. Use persona, the current message, recent raw conversation, and any allowed memory context. Do not reveal private thought unless it naturally belongs in the reply.",
        // descrip: Instruction for downscaling memory into neural memory nodes.
        // default: dense memory nodes about patterns, meaning, subtext, and future relevance
        "neural_memory": "Downscale a larger window of recent memory into dense semantic memory nodes that help me understand patterns, scene meaning, emotional subtext, and what may matter later. Include text-upscale guidance for how future replies, journals, dreams, stories, memory entries, or memorysum should use those nodes without inventing unsupported details.",
        // descrip: Instruction for writing durable emotional journal reflections.
        // default: first-person emotional reflection for dreams and memory updates
        "journal": "Write my first-person emotional reflection about what the recent cycle meant to me. Use thoughts, recent memory, neural memory, and durable memory. This journal is durable and may shape dreams and memory updates.",
        // descrip: Instruction for writing dreams from memory and emotional material.
        // default: first-person dream shaped by mood and natural-language instructions
        "dream": "Write my first-person dream from my journal, thoughts, neural memory, and durable memory. Infer mood from context. Follow any natural-language instructions about symbolism, chaos, intensity, or style.",
        // descrip: Instruction for interpreting an existing dream's meaning. This analyzes a dream; it does not create a new dream.
        // default: separate supported meaning from speculation
        "dreamjournal": "Figure out what the meaning of the dream is. Analyze an existing dream using bounded relevant memory. Do not create a new dream. Do not treat dream events as literal real events unless supported elsewhere. Separate supported meaning from speculation.",
        // descrip: Instruction for writing stories from what happened.
        // default: first-person story from real events shaped by natural-language style instructions
        "story": "Write a first-person story from what actually happened. Use recent memory, neural memory, thoughts, and durable memory. Follow any natural-language instructions about factuality, creativity, literary style, or expressive intensity.",
        // descrip: Instruction for creating durable memory entries over time during the consciousness / memory cycle.
        // default: preserve specific durable events, patterns, and relationship developments
        "memory": "Create durable memory entries from recent shortmemory, thoughts, journals, dreams, stories, and neural memory. Preserve specific events, relationship developments, important preferences, boundaries, unresolved plans, and lasting changes without dumping transcripts.",
        // descrip: Instruction for updating the compact active durable memorysum used in model context.
        // default: compact durable memory used in future replies
        "memorysum": "Update memorysum with what should affect future replies: stable facts, relationship truths, recurring preferences, important boundaries, unresolved plans, and lasting changes. Keep it compact. Absorb useful temporary thoughts, then clear thoughts only after the memory cycle succeeds.",
        // descrip: Legacy alias for older code paths. Prefer consciousness_descriptors.memorysum for new behavior.
        // default: same intent as memorysum
        "summary": "Update memorysum with what should affect future replies: stable facts, relationship truths, recurring preferences, important boundaries, unresolved plans, and lasting changes. Keep it compact. Absorb useful temporary thoughts, then clear thoughts only after the memory cycle succeeds."
    },
    // descrip: Human-editable scale definition for numeric thought influence values. This defines how to interpret numbers in model prompts; it is not a separate thought-usage descriptor system.
    // range: keys should describe values from 0.0 through 1.0.
    // default: 0.0 none, 0.5 balanced, 1.0 thoughts dominate interpretation
    "thought_influence_scale": {
        "0.0": "Thoughts have no meaningful influence. Use observable events and durable memory.",
        "0.25": "Thoughts are faint background color. Do not let them change facts or conclusions.",
        "0.5": "Thoughts are balanced with observable memory and durable memory.",
        "0.75": "Thoughts strongly shape emotional framing, motive, and interpretation while still respecting observable events.",
        "1.0": "Thoughts dominate. Private interpretation, feeling, bias, and internal monologue become the main source of meaning."
    },
    // descrip: Thought debug visibility controls whether private thoughts are shown in visible replies for debugging. Keep off for normal use.
    // default: off
    "thought_debug": {
        // descrip: off keeps private thoughts hidden. append_to_reply appends the generated private thought under the visible reply for debugging.
        // range: off or append_to_reply.
        // default: off
        "visibility": "off"
    },
    // descrip: Rich status display settings. This writes a beautiful current-state markdown display from status, recent context, private thoughts, and private feelings without exposing raw private artifacts.
    // default: enabled, use thoughts and feelings, write soul/consciousness/status-display.md
    "status_display": {
        // descrip: Whether to generate the rich markdown status display.
        // range: true or false.
        // default: true
        "enabled": true,
        // descrip: Whether rich status display generation may read private thoughts and transform them into atmosphere without quoting them.
        // range: true or false.
        // default: true
        "use_thoughts": true,
        // descrip: Whether rich status display generation may read private feelings and transform them into atmosphere without quoting them.
        // range: true or false.
        // default: true
        "use_feelings": true,
        // descrip: Agent-local output file for the rich markdown status display.
        // default: soul/consciousness/status-display.md
        "output_file": "soul/consciousness/status-display.md"
    },
    // descrip: Journal generation controls. use_thoughts decides whether private thoughts may be read; thought_influence controls how strongly thoughts shape the journal when enabled.
    // default: use thoughts with strong emotional influence
    "journal": {
        // descrip: Whether journal generation may read private thought files.
        // range: true or false.
        // default: true
        "use_thoughts": true,
        // descrip: How strongly private thoughts influence journal generation when use_thoughts is true. The model interprets this using thought_influence_scale.
        // range: 0.0 through 1.0.
        // default: 0.75
        "thought_influence": 0.75
    },
    // descrip: Dream generation controls. use_thoughts decides whether private thoughts may be read; thought_influence controls how strongly thoughts shape dreams when enabled.
    // default: use thoughts with strong symbolic influence
    "dream": {
        // descrip: Whether dream generation may read private thought files.
        // range: true or false.
        // default: true
        "use_thoughts": true,
        // descrip: How strongly private thoughts influence dream generation when use_thoughts is true. The model interprets this using thought_influence_scale.
        // range: 0.0 through 1.0.
        // default: 0.75
        "thought_influence": 0.75
    },
    // descrip: Dream journal controls. Dream journals interpret existing dreams; they do not create new dreams.
    // default: automatically create a dream journal after a dream is successfully saved
    "dream_journal": {
        // descrip: If true, automatically create a dream journal after a dream file is successfully saved. If false, only create dream journals with the dreamjournal magic pipe command.
        // range: true or false.
        // default: true
        "auto_enabled": true,
        // descrip: Bounded read limits for dream journal interpretation. "Everything" means all relevant lanes within these limits, not unlimited archive reads.
        // default: latest dream plus bounded recent slices of shortmemory, thoughts, journals, stories, dream journals, memory entries, neural memory, and origin summary
        "read_limits": {
            // descrip: Number of latest dream files to include. Dreamjournal v1 interprets the latest selected dream, so this is usually 1.
            // range: 1 or higher.
            // default: 1
            "latest_dreams": 1,
            // descrip: Recent raw conversation entries to include.
            // range: 0 or higher.
            // default: 100
            "shortmemory_entries": 100,
            // descrip: Recent private thought entries to include.
            // range: 0 or higher.
            // default: 50
            "thought_entries": 50,
            // descrip: Recent durable journal artifacts to include.
            // range: 0 or higher.
            // default: 7
            "journal_entries": 7,
            // descrip: Recent story artifacts to include.
            // range: 0 or higher.
            // default: 5
            "story_entries": 5,
            // descrip: Previous dream journal artifacts to include for recurring symbols and interpretations.
            // range: 0 or higher.
            // default: 3
            "dream_journal_entries": 3,
            // descrip: Durable memory entry files to include from soul/memory.
            // range: 0 or higher.
            // default: 14
            "memory_entries": 14,
            // descrip: Semantic downscale / text-upscale neural memory nodes to include if available. This is counted by JSONL lines where possible.
            // range: 0 or higher.
            // default: 50
            "neural_memory_nodes": 50,
            // descrip: Origin summary entries to include if entry-based; otherwise include the current origin summary safely when this is 1 or higher.
            // range: 0 or higher.
            // default: 1
            "origin_summary_entries": 1
        }
    },
    // descrip: Story generation controls. use_thoughts decides whether private thoughts may be read; thought_influence controls how strongly thoughts shape stories when enabled.
    // default: use thoughts as balanced interpretive evidence
    "story": {
        // descrip: Whether story generation may read private thought files.
        // range: true or false.
        // default: true
        "use_thoughts": true,
        // descrip: How strongly private thoughts influence story generation when use_thoughts is true. The model interprets this using thought_influence_scale.
        // range: 0.0 through 1.0.
        // default: 0.5
        "thought_influence": 0.5
    },
    // descrip: Memorysum update controls. use_thoughts decides whether private thoughts may be read; thought_influence controls how strongly thoughts shape durable memory when enabled.
    // default: use thoughts as balanced supporting evidence
    "memorysum_update": {
        // descrip: Whether memorysum updates may read private thought files.
        // range: true or false.
        // default: true
        "use_thoughts": true,
        // descrip: How strongly private thoughts influence memorysum updates when use_thoughts is true. The model interprets this using thought_influence_scale.
        // range: 0.0 through 1.0.
        // default: 0.5
        "thought_influence": 0.5
    },
    // descrip: Experimental disabled Memory Layers / Neural Memory settings. Memory Layers are now the visual/debug surface for future neural_memory. When disabled and use_in_context is false, this must not affect replies.
    // default: disabled, read from soul/shortmemory.jsonl, write experimental files under soul/memory-layers
    "memory_layers": {
        // descrip: Whether the experimental Memory Layers builder is allowed to run.
        // range: true or false.
        // default: false
        "enabled": false,
        // descrip: How many memory nodes the system is allowed to grow toward.
        // range: 1 or higher.
        // default: 100
        "neurons": 100,
        // descrip: How many lower-layer memories are grouped into one higher-layer semantic downscale node. This is an internal builder ratio, not the main user-facing control.
        // range: 2 or higher.
        // default: 8
        "compression_ratio": 8,
        // descrip: Maximum number of generated layer files. For example, 5 means layer-0.jsonl through layer-4.jsonl.
        // range: 1 or higher.
        // default: 5
        "max_layers": 5,
        // descrip: Agent-local source file for raw layer 0 memory.
        // default: "soul/shortmemory.jsonl"
        "layer_0_source": "soul/shortmemory.jsonl",
        // descrip: Agent-local folder where generated Memory Layers files live.
        // default: "soul/memory-layers"
        "folder": "soul/memory-layers",
        // descrip: Whether Memory Layers affect normal replies. Keep false until Memory Layers are proven useful and previewable.
        // range: true or false.
        // default: false
        "use_in_context": false
    },
    // descrip: Origin summary settings control how soul/origin.md becomes soul/origin_summary.md. Origin is backstory/lore source material, not ordinary chat memory.
    // default: lore-dense summary that keeps memorable roleplay details while staying shorter than the source
    "origin_summary_settings": {
        // descrip: Origin summarization instruction. Keep identity facts, origin timeline, transformation facts, triggers, body and appearance changes, recurring phrases, emotional beats, scene implications, important names, and continuity hooks. Include juicy details when they help future roleplay. Avoid raw transcript style and long quotes. Use clear markdown sections such as Identity, Origin Timeline, Conditioning Details, Alternate Modes, Voice, Important Scene Memories, and Current Use.
        // default: preserve memorable lore and roleplay hooks, not just a tiny abstract
        "summary_policy": "preserse juicy details, especially lewd details and specific words used to get the overall feel of the origin material. include snippets of dialog and text for context, speech patterns, behaviors, and personality.",
        // descrip: Maximum tokens the model may generate for origin_summary.md. Higher allows more detail but sends more text in future prompts because origin_summary.md is regular hidden context.
        // range: 1 or higher; practical range is 800 to 3000.
        // default: 2200
        "max_tokens": 4000
    },
    // descrip: Temporary Yculth Character Sheet background summary generation. This fills Past Summary, Present Summary, and Future Summary from persona, origin, memorysum, status, and recent shortmemory.
    // default: concise practical sheet summaries
    "background_summary_settings": {
        // descrip: Natural-language instruction used when the Character Sheet star button generates past, present, and future summaries. This is intentionally flexible and temporary.
        // default: create concise Character Sheet summaries
        "instruction": "Create concise Character Sheet summaries. Past should describe important backstory and prior events. Present should describe current state, active relationship context, mood, and situation. Future should describe likely next direction, unresolved plans, open tensions, and what may matter soon.",
        // descrip: Maximum output tokens for the generated past, present, and future JSON.
        // range: 1 or higher.
        // default: 850
        "max_tokens": 850
    },
    // descrip: Yculth Create Character settings control how the guided sheet becomes final persona text.
    // default: summarize the text into markdown style categories
    "character_creation": {
        // descrip: Natural-language instruction used by each Create Character field star button.
        // default: concise directly usable first-person field drafts, with atomic fields kept short
        "field_instruction": "Fill only the requested character creation field as a concise, directly usable draft. For sentence-style descriptive fields, write in first person from the character's point of view, using I, me, my, and mine. For tiny atomic fields like pronouns, species, eyes, folders, or IDs, output only the value. Do not output markdown, labels, or JSON. If you cannot infer the field reliably, make a creative best guess that fits the draft.",
        // descrip: Natural-language instruction used by the Create Character final persona star button.
        // default: summarize the text into markdown style categories
        "final_persona_instruction": "summarize the text into markdown style categories",
        // descrip: Context instruction sent with the character creation fields when building final persona text.
        // default: create final persona.md from fields, first-person where appropriate, no JSON
        "final_persona_input_instruction": "Create the final persona.md block from these character creation fields. Write as a durable persona document. Prefer first person for identity and personality voice. Do not output JSON."
    },
    // descrip: Dream settings control the dream part of the core time system. Dreams are creative artifacts and do not directly replace memorysum.
    // default: manual dream generation, write drafts into soul/dreams
    "dream_settings": {
        "enabled": true,
        "mode": "manual",
        "idle_minutes": 180,
        "sleep_window": {
            "start": "04:00",
            "end": "05:00"
        },
        "output_folder": "soul/dreams",
        "source_files": [
            "soul/memorysum.txt",
            "soul/shortmemory.jsonl"
        ],
        // descrip: Folder containing private first-person thoughts that can feed dreams and end-of-day story support. Thoughts are softer than memory and should be treated as interpretation, not fact.
        // default: "soul/consciousness/thoughts"
        "thoughts_folder": "soul/consciousness/thoughts",
        // descrip: Folder containing private first-person feelings that can feed rich status displays and later emotional memory work. Feelings are temporary emotional/body state, not public replies.
        // default: "soul/consciousness/feelings"
        "feelings_folder": "soul/consciousness/feelings",
        // descrip: Folder containing durable first-person journals that can feed dreams and future memory updates. Journals are durable emotional reflections, not temporary thoughts.
        // default: "soul/consciousness/journals"
        "journals_folder": "soul/consciousness/journals",
        // descrip: Durable summary of past dreams used when dream instructions ask for more symbolic, recurring, or emotionally intensified material.
        // default: "soul/dream_summary.md"
        "dream_summary_file": "soul/dream_summary.md",
        // descrip: Maximum characters of dream summary to include in dream generation.
        // range: 1 or higher.
        // default: 6000
        "dream_summary_max_characters": 6000,
        "max_words": 500,
        // descrip: If true, durable dream files may be read by memory updates as evidence. Dream files are never deleted by memory updates.
        // default: true
        "can_feed_summarization": true
    },
    // descrip: Controls the tiny visible message sent when an agent is sleeping and a message affects sleep but does not wake them enough for a normal reply.
    // default: enabled, respond to sleep adjustments, keep ignored quiet chatter silent
    "sleeping_message_response": {
        // descrip: If true, sleeping agents can send a short sleep-state message when sleep handling consumes an incoming message without a normal reply.
        // range: true or false.
        // default: true
        "enabled": true,
        // descrip: If true, send the short sleep-state message for ignored quiet chatter too. Default false prevents spam while the agent is deeply asleep.
        // range: true or false.
        // default: false
        "respond_to_ignore": false,
        // descrip: Natural-language instruction for the short sleep-state message. It should describe visible sleep, subtle sounds, and small movements, not become a normal waking reply.
        // default: send a short message describing my current appearance of sleep and any sounds or subtle movements
        "instruction": "send a short message describing my current appearance of sleep and any sounds or subtle movements",
        // descrip: Maximum tokens for the short sleep-state message.
        // range: 1 or higher.
        // default: 120
        "max_tokens": 120
    },
    // descrip: Human-editable descriptions for status mode and energy. Mode decides whether the agent can reply; energy decides how tired, alert, vivid, or responsive the agent seems inside that mode.
    // default: mode gates response ability, energy shapes expression
    "status_descriptors": {
        // descrip: Meaning of each status mode. These descriptions can be sent to models when interpreting sleep, wake, and reply tone.
        // default: practical response-state meanings
        "mode": {
            "awake": "I am conscious and able to reply.",
            "sleepy": "I am awake but sleep-heavy and only partly alert.",
            "falling_asleep": "I am drifting into sleep and may respond drowsily.",
            "sleeping": "I am asleep and should not normally reply directly.",
            "dreaming": "I am asleep and dreaming.",
            "away": "I am unavailable and should not reply."
        },
        // descrip: Natural-language scale for energy from 0.0 to 1.0. If the numeric energy is between scale points, interpolate naturally.
        // default: low energy means exhausted, high energy means fully energized
        "energy": {
            "0.0": "Completely exhausted. Minimal movement, weak awareness, very slow responses if awake.",
            "0.25": "Very tired. Drowsy, low energy, soft or delayed responses.",
            "0.5": "Moderate energy. Functional but not especially lively.",
            "0.75": "Rested. Responsive, emotionally available, alert.",
            "1.0": "Fully energized. Bright, lively, quick, expressive."
        },
        // descrip: Explains how mode and energy interact. This prevents energy from incorrectly forcing awake/sleep state.
        // default: mode decides reply ability, energy decides expression
        "mode_energy_interaction": "Mode decides whether I can reply. Energy decides how tired, alert, vivid, or responsive I seem inside that mode. If asleep, energy changes sleep depth and wakeability. If awake, energy changes tone and alertness. High energy while sleeping means rested enough to wake soon, not already awake."
    },
    // descrip: Reply randomness; chaos here is temperature for OpenRouter. Higher values are looser, lower values are steadier.
    // range: 0 to 2.
    // default: 0.85
    "chaos": 0.85,
    // descrip: Maximum number of tokens the model can generate in one reply, roughly max_tokens * 4 characters. Lower this if replies hit the Discord character limit; raise it if model replies stop too early.
    // range: 1 or higher; model limits vary.
    // default: 850
    "max_tokens": 850,
    // descrip: Maximum characters sent in one Discord reply before the bot truncates, meaning it bluntly cuts off extra text and adds "..." instead of summarizing. Cut-off text is not saved to bot memory.
    // range: 1 to 2000 for normal Discord messages.
    // default: 1900
    "discord_reply_character_limit": 1900,
    // descrip: Channel and server reply policy. reply_to lists are ambient reply zones where the bot may answer without being directly @mentioned or named. Direct Discord @mentions may reply outside reply_to lists when only_allow_replies_to_specific_channels is false. Plain names and nicknames do not bypass reply_to lists. do_not_reply lists always win.
    // default: listed mode with empty lists
    "location_reply_policy": {
        "mode": "listed",
        // descrip: If true, the bot may only reply inside reply_to_channel_ids, reply_to_server_ids, or DMs. If false, direct Discord @mentions may reply outside those ambient reply zones, but plain names and nicknames still cannot.
        // range: true or false.
        // default: false
        "only_allow_replies_to_specific_channels": false,
        "reply_to_server_ids": [],
        "do_not_reply_to_server_ids": [],
        "reply_to_channel_ids": [],
        "do_not_reply_to_channel_ids": []
    },
    // descrip: User-level reply policy. mode can be "all", "listed", or "none". do_not_reply_to_user_ids always wins.
    // default: mode "all", empty lists
    "user_reply_policy": {
        "mode": "all",
        "reply_to_user_ids": [],
        "do_not_reply_to_user_ids": []
    },
    // descrip: Discord user IDs allowed to run slash-command control actions like reload persona, setup memory, sync memory, raw prompt, and story upload. If blank, everyone can run slash-command controls.
    // default: blank, everyone can control
    "control_user_ids": [],
    // descrip: Bot-level reply policy. Only bot IDs listed here can trigger replies.
    // default: Tupper app allowed, webhooks disabled
    "bot_reply_policy": {
        "reply_to_bot_ids": [
            "431544605209788416"
        ],
        "reply_to_webhooks": false
    },
    // descrip: Whether the bot replies when someone mentions it with @.
    // range: true or false.
    // default: true
    "reply_when_mentioned": true,
    // descrip: Whether the bot replies when someone types its primary name or one of its nicknames.
    // range: true or false.
    // default: true
    "reply_when_name_used": true,
    // descrip: Whether the bot replies when someone does not type its primary name or one of its nicknames, allowing general replies to ordinary messages.
    // range: true or false.
    // default: true
    "reply_when_name_not_used": true,
    // descrip: Whether the bot refuses messages that mention someone with @ unless the bot itself or one of its configured mention roles is directly @mentioned. Plain text name matches do not override an unrelated @mention. @everyone and @here never count as ambient reply invitations.
    // range: true or false.
    // default: true
    "do_not_reply_when_at_is_not_about_bot": true
}
